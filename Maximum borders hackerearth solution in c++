#include <bits/stdc++.h>
using namespace std;
typedef long long ll;

const int b = 1e3 + 14;
char c[b][b];
int main()
{
	int t;
	cin >> t;
	while(t--)
	{
		int n, m;
		cin >> n >> m;
		for(int i = 1; i <= n; i++)
		{
			cin >> (c[i] + 1);
		}
		int ans = 0;
		for(int i = 1; i <= n; i++)
		{
			for(int j = 1, a = 1; j <= m; j = a)
			{
				if(c[i][j] != '#' || c[i - 1][j] == '#')
				{
					a++;
				}
				else{
					while(c[i][a] == '#' && c[i - 1][a] != '#')
					{
						a++;
					ans = max(ans, a - j);
					}
				}
			}
		}
		for(int i = 1; i <= n; i++)
		{
			for(int j = 1, a = 1; j <= m; j = a)
			{
				if(c[i][j] != '#' || c[i + 1][a] == '#')
				{
					a++;
				}

				else{
					while(c[i][a] == '#' && c[i + 1][a] != '#')
					{
						a++;
					ans = max(ans, a - j);
					}				
								
				}
			}
		}
		for(int i = 1; i <= m; i++)
		{
			for(int j = 1, a = 1; j <= n; j = a)
			{
				if(c[j][i] != '#' || c[j][i - 1] == '#')
				{
					a++;
			}
				else{
					while(c[a][i] == '#' && c[a][i - 1] != '#')
						a++;
					ans = max(ans, a - j);
				}
			}
		}
		for(int i = 1; i <= m; i++)
		{
			for(int j = 1, a = 1; j <= n; j = a)
			{
				if(c[j][i] != '#' || c[j][i + 1] == '#')
				{
					a++;
				}
				else{
					while(c[a][i] == '#' && c[a][i + 1] != '#')
						a++;
					ans = max(ans, a - j);
				}
			}
		}

		cout << ans << '\n';
	}
}
